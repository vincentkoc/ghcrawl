{
  "name": "@gitcrawl/api-core",
  "version": "0.0.0",
  "type": "module",
  "description": "Gitcrawl core library for GitHub sync, SQLite storage, embeddings, search, and clustering",
  "author": "PwrDrvr LLC <harold@pwrdrvr.com>",
  "license": "MIT",
  "homepage": "https://github.com/pwrdrvr/gitcrawl",
  "bugs": {
    "url": "https://github.com/pwrdrvr/gitcrawl/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pwrdrvr/gitcrawl.git"
  },
  "keywords": [
    "gitcrawl",
    "github",
    "sqlite",
    "openai",
    "embeddings",
    "clustering"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@gitcrawl/api-contract": "workspace:*",
    "@shutterstock/p-map-iterable": "^1.1.2",
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.1",
    "octokit": "^5.0.3",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.2.2",
    "openai": "^5.20.3",
    "zod": "^3.25.76"
  }
}
