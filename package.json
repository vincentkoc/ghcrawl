{
  "name": "gitcrawl",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Local-first GitHub issue and pull request crawler with clustering and a terminal UI",
  "author": "PwrDrvr LLC <harold@pwrdrvr.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "cli": "pnpm --filter @gitcrawl/cli cli",
    "init": "pnpm --filter @gitcrawl/cli cli init",
    "bootstrap": "pnpm --filter @gitcrawl/cli cli init",
    "doctor": "pnpm --filter @gitcrawl/cli cli doctor",
    "sync": "pnpm --filter @gitcrawl/cli cli sync",
    "summarize": "pnpm --filter @gitcrawl/cli cli summarize",
    "embed": "pnpm --filter @gitcrawl/cli cli embed",
    "cluster": "pnpm --filter @gitcrawl/cli cli cluster",
    "search": "pnpm --filter @gitcrawl/cli cli search",
    "neighbors": "pnpm --filter @gitcrawl/cli cli neighbors",
    "tui": "pnpm --filter @gitcrawl/cli cli tui",
    "serve": "pnpm --filter @gitcrawl/cli cli serve",
    "pack:smoke": "node ./scripts/pack-smoke.mjs",
    "release:apply-version": "node ./scripts/apply-release-version.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
